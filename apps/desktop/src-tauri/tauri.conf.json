{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "sailviz",
  "version": "0.1.0",
  "identifier": "com.sailviz",
  "build": {
    "frontendDist": "../../../apps/web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter web run dev"
  },
  "app": {
    "windows": [
      {
        "title": "sailviz",
        "fullscreen": false,
        "url": "Login"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/mnt/z/Sailviz/node_modules/.pnpm/prisma@6.16.3_typescript@5.9.3/node_modules/prisma/build/node_modules:/mnt/z/Sailviz/node_modules/.pnpm/prisma@6.16.3_typescript@5.9.3/node_modules/prisma/node_modules:/mnt/z/Sailviz/node_modules/.pnpm/prisma@6.16.3_typescript@5.9.3/node_modules:/mnt/z/Sailviz/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/mnt/z/Sailviz/node_modules/.pnpm/prisma@6.16.3_typescript@5.9.3/node_modules/prisma/build/node_modules:/mnt/z/Sailviz/node_modules/.pnpm/prisma@6.16.3_typescript@5.9.3/node_modules/prisma/node_modules:/mnt/z/Sailviz/node_modules/.pnpm/prisma@6.16.3_typescript@5.9.3/node_modules:/mnt/z/Sailviz/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../prisma/build/index.js" "$@"
else
  exec node  "$basedir/../../../../prisma/build/index.js" "$@"
fi

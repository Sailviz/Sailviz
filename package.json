{
  "scripts": {
    "dev:dev:web": "concurrently -n \"API,WEB\" -c \"blue,green\" \"pnpm --filter api dev\" \"pnpm --filter web dev\"",
    "dev:dev:desktop": "concurrently -n \"API,TAURI\" -c \"blue,magenta\" \"pnpm --filter api dev\" \"pnpm --filter desktop dev:desktop\"",
    "dev:test:desktop": "pnpm --filter desktop dev:test:desktop",
    "bundle:test:desktop": "pnpm --filter web build:test && pnpm --filter desktop build:test:desktop && pnpm --filter desktop bundle:test:desktop",
    "bundle:prod:desktop": "pnpm --filter web build:prod && pnpm --filter desktop build:prod:desktop && pnpm --filter desktop bundle:prod:desktop",
    "dev:api": "pnpm --filter api dev",
    "build:android:test": "pnpm --filter desktop android:test\"",
    "build:android:prod": "pnpm --filter desktop android:prod\"",
    "load:android:test": "pnpm --filter desktop load:test",
    "build:dev:web": "pnpm --filter web build:dev",
    "build:test:web": "pnpm --filter web build:test",
    "build:prod:web": "pnpm --filter web build:prod",
    "build:dev:api": "pnpm --filter @sailviz/api run build:dev",
    "build:test:api": "pnpm --filter @sailviz/api run build:test",
    "build:prod:api": "pnpm --filter @sailviz/api run build:prod",
    "build:test:desktop": "pnpm --filter web build:test && pnpm --filter desktop build:test:desktop",
    "build:prod:desktop": "pnpm --filter web build:prod && pnpm --filter desktop build:prod:desktop",
    "prismagenerate": "pnpm --filter @sailviz/db run prismagenerate",
    "prismapush": "pnpm --filter @sailviz/db run prismapush"
  },
  "packageManager": "pnpm@10.18.1+sha512.77a884a165cbba2d8d1c19e3b4880eee6d2fcabd0d879121e282196b80042351d5eb3ca0935fa599da1dc51265cc68816ad2bddd2a2de5ea9fdf92adbec7cd34",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "dotenv-cli": "^10.0.0",
    "cross-env": "^7.0.3"
  }
}

{
  "name": "@sailviz/api",
  "dependencies": {
    "@orpc/client": "^1.9.3",
    "@orpc/server": "^1.9.3",
    "better-auth": "^1.3.27",
    "cors": "^2.8.5",
    "dayjs": "^1.11.18",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "stripe": "^19.1.0",

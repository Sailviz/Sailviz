{
  "name": "@sailviz/auth",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "default": "./dist/auth.js"
    }
  },
  "scripts": {
    "prebuild": "node ../../packages/db/scripts/generate-config.js && pnpm -w --filter @sailviz/types build && pnpm -w --filter @sailviz/db build && npm run generateConfig",
    "generateConfig": "node scripts/generate-config.js",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@sailviz/db": "workspace:*",
    "@sailviz/types": "workspace:*",
    "@orpc/server": "^1.9.3",
    "better-auth": "^1.4.10",
    "@better-auth/utils": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "dotenv": "^17.2.3"
  }
}

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model globalConfig {
  id           String  @id @unique @default(uuid())
  active       Boolean
  demoClubId   String
  demoSeriesId String
  demoDataId   String
  demoUUID     String
}

model User {
  id                String              @id @unique @default(uuid())
  startPage         String
  name              String              @default("")
  email             String?             @unique
  emailVerified     Boolean
  isAnonymous       Boolean             @default(false)
  image             String?             @db.Text
  createdAt         DateTime
  updatedAt         DateTime
  sessions          Session[]
  accounts          Account[]
  members           Member[]
  invitations       Invitation[]
  results           Result[]
  teamMembers       teamMember[]
  userFavouriteOrgs UserFavouriteOrgs[]
  signOnProfiles    signOnProfile[]

  @@map("user")
}

model UserFavouriteOrgs {
  id           String       @id @unique @default(uuid())
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])
  userId       String?
}

model signOnProfile {
  id         String @id @unique @default(uuid())
  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  Helm       String
  Crew       String
  SailNumber String
  Boat       Boat   @relation(fields: [boatId], references: [id])
  boatId     String
}

model Boat {
  id             String          @id @unique @default(uuid())
  name           String
  crew           Int
  py             Int
  results        Result[]
  fleets         FleetSettings[] @relation("BoatToFleetSettings")
  signOnProfiles signOnProfile[]
  boatOverrides  BoatOverride[]
}

model BoatOverride {
  id               String       @id @unique @default(uuid())
  boatId           String
  boat             Boat         @relation(fields: [boatId], references: [id], onDelete: Cascade)
  crew             Int
  py               Int
  pursuitStartTime Int
  orgId            String
  organization     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Organization {
  id                String              @id @unique @default(uuid())
  name              String              @unique
  slug              String
  logo              String?
  createdAt         DateTime
  metadata          String?             @db.Text
  Buoy              Buoy[]
  series            Series[]
  Trackers          Tracker[]
  stripe            Stripe?             @relation(fields: [stripeCustomerId], references: [customerId])
  stripeCustomerId  String?
  members           Member[]
  invitations       Invitation[]
  teams             Team[]
  userFavouriteOrgs UserFavouriteOrgs[]
  boatOverrides     BoatOverride[]
  orgData           orgData?
  orgDataId         String?             @unique
  tags              Tag[]
  flags             Flag[]
}

model orgData {
  id                       String       @id @unique @default(uuid())
  planName                 String?
  subscriptionStatus       String?
  defaultPursuitLength     Int          @default(60)
  trackableEnabled         Boolean
  trackableOrgId           String?
  duties                   Duties[]
  organization             Organization @relation(references: [id], fields: [organizationId])
  organizationId           String       @unique
  defaultClassFlag         Flag?        @relation("OrgDataDefaultClassFlag", fields: [defaultClassFlagId], references: [id])
  defaultClassFlagId       String?
  defaultPreparatoryFlag   Flag?        @relation("OrgDataDefaultPreparatoryFlag", fields: [defaultPreparatoryFlagId], references: [id])
  defaultPreparatoryFlagId String?
}

model Duties {
  id        String  @id @unique @default(uuid())
  orgDataId String
  name      String
  orgData   orgData @relation(fields: [orgDataId], references: [id])
}

model Member {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @db.Text
  createdAt      DateTime

  @@map("member")
}

model Team {
  id             String       @id @unique @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  teamMembers    teamMember[]
}

model teamMember {
  id        String   @id @unique @default(uuid())
  teamId    String
  userId    String
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invitation {
  id             String       @id
  organizationId String
  teamId         String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String       @db.Text
  role           String?      @db.Text
  status         String       @db.Text
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@map("invitation")
}

model Stripe {
  customerId String @id @unique

  subscriptionId     String?
  productId          String?
  planName           String?
  subscriptionStatus String?
  updatedAt          String?
  organization       Organization[]
}

model Tag {
  id           String       @id @unique @default(uuid())
  name         String
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  series       Series[]
}

model Series {
  id            String          @id @unique @default(uuid())
  name          String
  orgId         String
  tags          Tag[]
  settings      Json
  fleetSettings FleetSettings[]
  races         Race[]
  organization  Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  startSequence String          @default("541go") // can be "321go", "541go"
}

model Race {
  id                String       @id @unique @default(uuid())
  trackableEventId  String?
  number            Int
  sequenceStartTime Int          @default(0)
  Time              String
  Type              String
  seriesId          String
  Duties            Json
  fleets            Fleet[]
  courseBuoys       CourseBuoy[]
  series            Series       @relation(fields: [seriesId], references: [id], onDelete: Cascade)
}

model CourseBuoy {
  id     String @id @unique @default(uuid())
  raceId String
  order  Int
  side   String
  buoy   Buoy   @relation(fields: [buoyId], references: [id])
  race   Race   @relation(fields: [raceId], references: [id])
  buoyId String
}

model FleetSettings {
  id                String  @id @unique @default(uuid())
  seriesId          String
  name              String
  start             Int     @default(0)
  fleets            Fleet[]
  series            Series  @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  boats             Boat[]  @relation("BoatToFleetSettings")
  preparatoryFlag   Flag    @relation("FleetPreparatoryFlag", fields: [preparatoryFlagId], references: [id])
  preparatoryFlagId String
  classFlag         Flag    @relation("FleetClassFlag", fields: [classFlagId], references: [id])
  classFlagId       String
}

model Fleet {
  id            String        @id @unique @default(uuid())
  raceId        String
  startTime     Int
  recalls       Int           @default(0)
  settingsId    String
  race          Race          @relation(fields: [raceId], references: [id], onDelete: Cascade)
  fleetSettings FleetSettings @relation(fields: [settingsId], references: [id])
  results       Result[]
}

model Result {
  id                     String  @id @unique @default(uuid())
  fleetId                String?
  Helm                   String
  Crew                   String
  boatId                 String?
  SailNumber             String
  finishTime             Int
  CorrectedTime          Float
  HandicapPosition       Int
  PursuitPosition        Int
  isDeleted              Boolean
  resultCode             String
  numberLaps             Int
  laps                   Lap[]
  boat                   Boat?   @relation(fields: [boatId], references: [id])
  fleet                  Fleet?  @relation(fields: [fleetId], references: [id], onDelete: Cascade)
  userId                 String?
  user                   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackableParticipantId String?
}

model Lap {
  id        String  @id @unique @default(uuid())
  resultId  String
  time      Int
  isDeleted Boolean
  result    Result  @relation(fields: [resultId], references: [id])
}

model Tracker {
  trackerId    String       @id @unique
  orgId        String
  name         String
  organization Organization @relation(fields: [orgId], references: [id])
}

model Buoy {
  id           String       @id @unique @default(uuid())
  name         String
  orgId        String
  lat          Float
  lon          Float
  isMoveable   Boolean
  isStartLine  Boolean
  trackerId    String
  organization Organization @relation(fields: [orgId], references: [id])
  courseBuoys  CourseBuoy[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?  @db.Text
  userAgent String?  @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeOrganizationId String? @db.Text

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @db.Text
  providerId            String    @db.Text
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?   @db.Text
  password              String?   @db.Text
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String    @db.Text
  value      String    @db.Text
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

enum ImageOwnerType {
  user
  organisation
  public
}

model Image {
  id        String         @id @unique @default(uuid())
  ownerType ImageOwnerType
  ownerId   String?
  category  String
  s3Key     String
  createdAt DateTime       @default(now())
}

model Flag {
  id           String          @id @unique @default(uuid())
  name         String
  s3key        String
  fleetsPrep   FleetSettings[] @relation("FleetPreparatoryFlag")
  fleetsClass  FleetSettings[] @relation("FleetClassFlag")
  orgId        String?
  organization Organization?   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orgDataClass orgData[]       @relation("OrgDataDefaultClassFlag")
  orgDataPrep  orgData[]       @relation("OrgDataDefaultPreparatoryFlag")
}

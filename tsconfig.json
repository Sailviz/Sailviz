{
  "compilerOptions": {
    "module": "esnext", // or "nodenext"
    "moduleResolution": "bundler", // or "node16" or "bundler
    "baseUrl": ".",
    "paths": {
      "@sailviz/db": ["packages/db/src"],
      "@sailviz/api/*": ["packages/api/src/*"],
      "@sailviz/auth": ["packages/auth/src"],
      "@sailviz/shared/*": ["packages/shared/*"]
    }
  }
}
